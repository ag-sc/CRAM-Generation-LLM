(<- (desig:action-grounding ?action-designator (place-down ?resolved-action-designator))
    (spec:property ?action-designator (:type :placing))
    (spec:property ?action-designator (:object ?object-designator))
    (desig:current-designator ?object-designator ?current-object-desig)
    (spec:property ?current-object-desig (:type ?object-type))
    (spec:property ?current-object-desig (:name ?object-name))
    (-> (spec:property ?action-designator (:arm ?arm))
        (true)
        (man-int:robot-free-hand ?_ ?arm))
    (lisp-fun man-int:get-object-old-transform ?current-object-desig ?object-transform)
    (-> (spec:property ?action-designator (:location ?location-designator))
        (true)
        (desig:current-designator ?location-designator ?current-location-desig))
    (lisp-fun man-int:get-location-transform ?current-location-desig ?location-transform)
    (lisp-fun man-int:get-action-grasps ?object-type ?arm ?object-transform ?grasps)
    (spec:property ?action-designator (:grasp (car ?grasps)))
    (lisp-fun man-int:get-action-gripping-effort ?object-type ?effort)
    (lisp-fun man-int:get-action-gripper-opening ?object-type ?gripper-opening)
    (equal ?objects (?current-object-desig))
    (-> (equal ?arm :left)
        (and (lisp-fun man-int:get-action-trajectory :placing ?arm (car ?grasps) T ?objects ?location-transform
                       ?left-placing-pose)
             (lisp-fun man-int:get-traj-poses-by-label ?left-placing-pose :place-down
                       ?left-place-down-poses))
        (equal ?left-place-down-poses NIL))
    (-> (equal ?arm :right)
        (and (lisp-fun man-int:get-action-trajectory :placing ?arm (car ?grasps) T ?objects ?location-transform
                       ?right-placing-pose)
             (lisp-fun man-int:get-traj-poses-by-label ?right-placing-pose :place-down
                       ?right-place-down-poses))
        (equal ?right-place-down-poses NIL))
    (-> (desig:desig-prop ?action-designator (:collision-mode ?collision-mode))
        (true)
        (equal ?collision-mode nil))
    (desig:designator :action ((:type :placing)
                               (:object ?current-object-desig)
                               (:object-name  ?object-name)
                               (:arm ?arm)
                               (:gripper-opening ?gripper-opening)
                               (:effort ?effort)
                               (:grasp (car ?grasps))
                               (:left-place-down-poses ?left-place-down-poses)
                               (:right-place-down-poses ?right-place-down-poses)
                               (:collision-mode ?collision-mode)
                               (:location ?current-location-desig))
                      ?resolved-action-designator))