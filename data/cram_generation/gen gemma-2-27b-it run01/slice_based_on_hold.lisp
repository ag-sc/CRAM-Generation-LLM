(<- (desig:action-grounding ?action-designator (pp-plans:slice ?resolved-action-designator))
      (spec:property ?action-designator (:type :slicing))
      (spec:property ?action-designator (:object ?object-designator))
      (desig:current-designator ?object-designator ?current-object-desig)
      (spec:property ?current-object-desig (:type ?object-type))
      (spec:property ?current-object-desig (:name ?object-name))
      (-> (spec:property ?action-designator (:arm ?arm))
          (true)
          (man-int:robot-free-hand ?_ ?arm))
      (lisp-fun man-int:get-object-transform ?current-object-desig ?object-transform)
      (lisp-fun man-int:calculate-object-faces ?object-transform (?facing-robot-face ?bottom-face))
      (-> (man-int:object-rotationally-symmetric ?object-type)
           (equal ?rotationally-symmetric t)
           (equal ?rotationally-symmetric nil))
      (-> (spec:property ?action-designator (:cut-point ?cut-point))
        (true)
        (and (lisp-fun man-int:get-object-cut-points ?object-type ?cut-points)
           (member ?cut-point ?cut-points)))
      (lisp-fun man-int:get-action-cutting-effort ?object-type ?effort)
      (lisp-fun man-int:get-action-cutting-speed ?object-type ?speed)
      (equal ?objects (?current-object-desig))
      (-> (equal ?arm :left)
          (and (lisp-fun man-int:get-action-trajectory :slicing ?arm ?cut-point T ?objects
                         ?left-trajectory)
               (lisp-fun man-int:get-traj-poses-by-label ?left-trajectory :reaching
                         ?left-reach-poses)
               (lisp-fun man-int:get-traj-poses-by-label ?left-trajectory :cutting
                         ?left-cut-poses))
          (and (equal ?left-reach-poses NIL)
               (equal ?left-cut-poses NIL)))
      (-> (equal ?arm :right)
          (and (lisp-fun man-int:get-action-trajectory :slicing ?arm ?cut-point T ?objects
                         ?right-trajectory)
               (lisp-fun man-int:get-traj-poses-by-label ?right-trajectory :reaching
                         ?right-reach-poses)
               (lisp-fun man-int:get-traj-poses-by-label ?right-trajectory :cutting
                         ?right-cut-poses))
          (and (equal ?right-reach-poses NIL)
               (equal ?right-cut-poses NIL)))
      (desig:designator :action ((:type :slicing)
                                 (:object ?current-object-desig)
                                 (:object-name  ?object-name)
                                 (:arm ?arm)
                                 (:effort ?effort)
                                 (:speed ?speed)
                                 (:cut-point ?cut-point)
                                 (:left-reach-poses ?left-reach-poses)
                                 (:right-reach-poses ?right-reach-poses)
                                 (:left-cut-poses ?left-cut-poses)
                                 (:right-cut-poses ?right-cut-poses))
                        ?resolved-action-designator)))