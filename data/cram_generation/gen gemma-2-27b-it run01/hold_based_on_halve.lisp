(<- (desig:action-grounding ?action-designator (hold ?resolved-action-designator))
    (spec:property ?action-designator (:type :holding))
    (spec:property ?action-designator (:object ?object-designator))
    (desig:current-designator ?object-designator ?current-object-desig)
    (spec:property ?current-object-desig (:type ?object-type))
    (spec:property ?current-object-desig (:name ?object-name))
    (-> (spec:property ?action-designator (:arm ?arm))
        (true)
        (man-int:robot-free-hand ?_ ?arm))
    (lisp-fun man-int:get-object-old-transform ?current-object-desig ?object-transform)
    (-> (spec:property ?action-designator (:grasp ?grasp))
        (true)
        (and (lisp-fun man-int:get-action-grasps ?object-type ?arm ?object-transform ?grasps)
             (member ?grasp ?grasps)))
    (lisp-fun man-int:get-action-gripping-effort ?object-type ?effort)
    (lisp-fun man-int:get-action-gripper-opening ?object-type ?gripper-opening)
    (equal ?objects (?current-object-desig))
    (-> (equal ?arm :left)
        (and (lisp-fun man-int:get-action-trajectory :holding ?arm ?grasp T ?objects
                       ?left-holding-pose)
             (lisp-fun man-int:get-traj-poses-by-label ?left-holding-pose :holding
                       ?left-holding-poses))
        (equal ?left-holding-poses NIL))
    (-> (equal ?arm :right)
        (and (lisp-fun man-int:get-action-trajectory :holding ?arm ?grasp T ?objects
                       ?right-holding-pose)
             (lisp-fun man-int:get-traj-poses-by-label ?right-holding-pose :holding
                       ?right-holding-poses))
        (equal ?right-holding-poses NIL))
    (-> (desig:desig-prop ?action-designator (:collision-mode ?collision-mode))
        (true)
        (equal ?collision-mode nil))
    (desig:designator :action ((:type :holding)
                               (:object ?current-object-desig)
                               (:object-name  ?object-name)
                               (:arm ?arm)
                               (:gripper-opening ?gripper-opening)
                               (:effort ?effort)
                               (:grasp ?grasp)
                               (:left-holding-poses ?left-holding-poses)
                               (:right-holding-poses ?right-holding-poses)
                               (:collision-mode ?collision-mode))
                      ?resolved-action-designator))