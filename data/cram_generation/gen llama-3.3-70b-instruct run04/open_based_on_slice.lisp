(<- (desig:action-grounding?action-designator (open?resolved-action-designator))
    (spec:property?action-designator (:type :opening))
    (spec:property?action-designator (:object?object-designator))
    (desig:current-designator?object-designator?current-object-desig)
    (spec:property?current-object-desig (:type?object-type))
    (spec:property?current-object-desig (:name?object-name))
    (-> (spec:property?action-designator (:arm?arm))
        (true)
        (man-int:robot-free-hand?_?arm))
    (lisp-fun man-int:get-object-old-transform?current-object-desig?object-transform)
    (lisp-fun man-int:calculate-object-faces?object-transform (?facing-robot-face?lid-face))
    (-> (spec:property?action-designator (:grasp?grasp))
        (true)
        (and (lisp-fun man-int:get-action-grasps?object-type?arm?object-transform?grasps)
             (member?grasp?grasps)))
    (lisp-fun man-int:get-action-gripping-effort?object-type?effort)
    (lisp-fun man-int:get-action-gripper-opening?object-type?gripper-opening)
    (equal?objects (?current-object-desig))
    (-> (equal?arm :left)
        (and (lisp-fun man-int:get-action-trajectory :opening?arm?grasp T?objects
                      ?left-opening-pose)
             (lisp-fun man-int:get-traj-poses-by-label?left-opening-pose :open-lid
                      ?left-open-lid-poses)
             (lisp-fun man-int:get-traj-poses-by-label?left-opening-pose :close-lid
                      ?left-close-lid-poses))
        (and (equal?left-open-lid-poses NIL)
             (equal?left-close-lid-poses NIL)))
    (-> (equal?arm :right)
        (and (lisp-fun man-int:get-action-trajectory :opening?arm?grasp T?objects
                      ?right-opening-pose)
             (lisp-fun man-int:get-traj-poses-by-label?right-opening-pose :open-lid
                      ?right-open-lid-poses)
             (lisp-fun man-int:get-traj-poses-by-label?right-opening-pose :close-lid
                      ?right-close-lid-poses))
        (and(equal?right-open-lid-poses NIL)
            (equal?right-close-lid-poses NIL)))
    (-> (desig:desig-prop?action-designator (:collision-mode?collision-mode))
        (true)
        (equal?collision-mode nil))
    (desig:designator :action ((:type :opening)
                               (:object?current-object-desig)
                               (:object-name ?object-name)
                               (:arm?arm)
                               (:gripper-opening?gripper-opening)
                               (:effort?effort)
                               (:grasp?grasp)
                               (:left-open-lid-poses?left-open-lid-poses)
                               (:right-open-lid-poses?right-open-lid-poses)
                               (:left-close-lid-poses?left-close-lid-poses)
                               (:right-close-lid-poses?right-close-lid-poses)
                               (:collision-mode?collision-mode))
                     ?resolved-action-designator))