(<- (desig:action-grounding?action-designator (pp-plans:cut?resolved-action-designator))
      (spec:property?action-designator (:type :halving))
      (spec:property?action-designator (:object?object-designator))
      (desig:current-designator?object-designator?current-object-desig)
      (spec:property?current-object-desig (:type?object-type))
      (spec:property?current-object-desig (:name?object-name))
      (-> (spec:property?action-designator (:arm?arm))
          (true)
          (man-int:robot-free-hand?_?arm))
      (lisp-fun man-int:get-object-transform?current-object-desig?object-transform)
      (lisp-fun man-int:calculate-object-faces?object-transform (?facing-robot-face?bottom-face))
      (-> (man-int:object-rotationally-symmetric?object-type)
           (equal?rotationally-symmetric t)
           (equal?rotationally-symmetric nil))
      (-> (spec:property?action-designator (:cutting-tool?cutting-tool))
        (true)
        (and (lisp-fun man-int:get-action-cutting-tools?object-type?arm?object-transform?cutting-tools)
           (member?cutting-tool?cutting-tools)))
      (lisp-fun man-int:get-action-cutting-effort?object-type?effort)
      (lisp-fun man-int:get-action-cutting-depth?object-type?cutting-depth)
      (equal?objects (?current-object-desig))
      (-> (equal?arm :left)
          (and (lisp-fun man-int:get-action-trajectory :cutting?arm?cutting-tool T?objects
                        ?left-trajectory)
               (lisp-fun man-int:get-traj-poses-by-label?left-trajectory :approaching
                        ?left-approach-poses)
               (lisp-fun man-int:get-traj-poses-by-label?left-trajectory :cutting
                        ?left-cut-poses))
          (and (equal?left-approach-poses NIL)
               (equal?left-cut-poses NIL)))
      (-> (equal?arm :right)
          (and (lisp-fun man-int:get-action-trajectory :cutting?arm?cutting-tool T?objects
                        ?right-trajectory)
               (lisp-fun man-int:get-traj-poses-by-label?right-trajectory :approaching
                        ?right-approach-poses)
               (lisp-fun man-int:get-traj-poses-by-label?right-trajectory :cutting
                        ?right-cut-poses))
          (and (equal?right-approach-poses NIL)
               (equal?right-cut-poses NIL)))
      (desig:designator :action ((:type :cutting)
                                 (:object?current-object-desig)
                                 (:object-name ?object-name)
                                 (:arm?arm)
                                 (:cutting-tool?cutting-tool)
                                 (:effort?effort)
                                 (:cutting-depth?cutting-depth)
                                 (:left-approach-poses?left-approach-poses)
                                 (:right-approach-poses?right-approach-poses)
                                 (:left-cut-poses?left-cut-poses)
                                 (:right-cut-poses?right-cut-poses)
                                 (:halve :halving))
                       ?resolved-action-designator))